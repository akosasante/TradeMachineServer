# TradeMachineServer — example environment (no secrets)
# ---------------------------------------------------------------------------
# Copy to `.env` and replace placeholders. Commit updates here whenever you
# add or rename server environment variables so deploys and onboarding stay
# discoverable. Do not put real credentials in this file.
#
# Docker-oriented templates with more deployment notes:
#   .env.staging.template / .env.prod.template

# ── Runtime & TypeORM connection name ─────────────────────────────────────
# ORM_CONFIG selects the TypeORM connection block in ormconfig.js (development | test | staging | production | …).
NODE_ENV=development
ORM_CONFIG=development
# Deploy/runtime label (staging | production | development). Drives session cookie names, Oban job env, metrics, SSO token prefixes.
APP_ENV=development
# Optional; some deploy docs set this for clarity alongside ORM_CONFIG
# DB_ENV=development

# Process layout (see src/bootstrap/express.ts)
BASE_DIR=/absolute/path/to/TradeMachineServer
IP=localhost
PORT=3000

# ── PostgreSQL (TypeORM + shared credentials) ────────────────────────────
PG_HOST=localhost
PG_PORT=5438
PG_USER=your_pg_user
PG_PASSWORD=your_pg_password
PG_DB=trade_machine
# Prisma (schema.prisma) — must match schema you use for v2/Prisma code paths
# Do not wrap the URL in quotes if you use Docker env-file.
DATABASE_URL=postgresql://your_pg_user:your_pg_password@localhost:5438/trade_machine?schema=dev&application_name=tm_server_dev

# Optional: non-public schema for legacy hydrated views (defaults to public)
# PG_SCHEMA=public

# ── Redis (sessions, Bull queues, cache) ──────────────────────────────────
REDIS_IP=localhost
REDIS_PORT=6380
REDISPASS=

# ── Session & cookies ─────────────────────────────────────────────────────
SESSION_SECRET=change_me_to_a_long_random_string
# Cookie domain for shared parent domain (optional)
# COOKIE_DOMAIN=.example.com
# Set COOKIE_SECURE=false for local HTTP; production should use secure cookies (default when NODE_ENV=test, insecure path is explicit)

# ── Logging ───────────────────────────────────────────────────────────────
# ENABLE_LOGS=false silences Winston (see src/bootstrap/logger.ts)
ENABLE_LOGS=true
DB_LOGS=false

# ── OpenTelemetry (optional) ───────────────────────────────────────────────
OTEL_SERVICE_NAME=trademachine-server
OTEL_SERVICE_VERSION=2.0.1
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# Optional overrides if you do not use the base endpoint above
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=
# OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=
OTEL_TRACES_SAMPLER=parentbased_always_on
OTEL_TRACES_SAMPLER_ARG=1.0
OTEL_LOG_LEVEL=INFO

# ── Email (Brevo / SendInBlue) ───────────────────────────────────────────
SENDINBLUE_SMTP_PASS=your_smtp_key_or_password
# Legacy / alternate API variables (see src/email/mailer.ts; may be unused depending on transport)
EMAIL_KEY_V3=your_brevo_api_key_v3
EMAIL_API_URL_V3=https://api.sendinblue.com/v3/smtp
EMAIL_KEY=your_brevo_api_key_v2
EMAIL_API_URL=https://api.sendinblue.com/v2.0

# Public API origin used in emails and some links (no trailing path)
BASE_URL=https://api.example.com

# ── Trade review V3 (magic links in email + tRPC) ─────────────────────────
# When USE_V3_TRADE_LINKS=true and V3_BASE_URL is set, eligible recipients get V3 URLs.
USE_V3_TRADE_LINKS=false
V3_BASE_URL=https://v3-client.example.com
# Comma-separated emails (case-insensitive) or a single * to allow any non-empty recipient email.
# Empty/unset => no V3 links (safe default).
# V3_TRADE_LINK_EMAIL_ALLOWLIST=alice@example.com,bob@example.com
# V3_TRADE_LINK_EMAIL_ALLOWLIST=*

# ── External integrations ─────────────────────────────────────────────────
ESPN_COOKIE=
ESPN_SWID=
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/REPLACE/REPLACE/REPLACE

# ── Rollbar ────────────────────────────────────────────────────────────────
# Environment label in Rollbar comes from ORM_CONFIG, not a separate env var.
ROLLBAR_ACCESS_TOKEN=

# ── Safety / local-only overrides ─────────────────────────────────────────
# ADMIN_OVERRIDE=true lets any authenticated user bypass legacy REST trade status checks (NEVER in production).
# ADMIN_OVERRIDE=false

# ── Docker image tag (deploy scripts / compose) ──────────────────────────
# IMAGE_TAG=staging

# ── Tests / CI (usually set by jest or GitHub Actions, not manually) ─────
# ORM_CONFIG=test
# SKIP_CACHE_IN_TEST=true
# CONTAINER_ENV=docker
# CI=true
# GITHUB_ACTIONS=true
# V2_EMAILS=test@example.com
